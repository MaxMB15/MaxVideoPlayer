{
  "$schema": "https://raw.githubusercontent.com/nichobi/tauri-apps/tauri-v2/core/tauri-config-schema/schema.json",
  "productName": "MaxVideoPlayer",
  "version": "0.1.0",
  "identifier": "com.maxvideoplayer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": {
      "script": "bash scripts/bundle-libmpv.sh",
      "cwd": "../.."
    },
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MaxVideoPlayer",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../resources"],
    "macOS": {
      "frameworks": [],
      "files": {
        "Frameworks": "../../libs/macos-bundle"
      },
      "minimumSystemVersion": "10.15"
    }
  }
}
