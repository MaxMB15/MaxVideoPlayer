{
	"$schema": "https://raw.githubusercontent.com/nichobi/tauri-apps/tauri-v2/core/tauri-config-schema/schema.json",
	"productName": "MaxVideoPlayer",
	"version": "0.4.6",
	"identifier": "com.maxvideoplayer.app",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"beforeBundleCommand": {
			"script": "bash scripts/bundle-libmpv.sh",
			"cwd": "../../.."
		},
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": true,
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "Max Video Player",
				"width": 1280,
				"height": 720,
				"resizable": true,
				"fullscreen": false,
				"decorations": true,
				"transparent": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEMjJBQTczNDYzMjgxRkIKUldUN2dUSkdjNm9pN1pZRlYyZnEvb0lYbWcreENJd0ZwVHdWeXFLT0U0U1hLWHF0YjA5TE1jU2YK",
			"endpoints": [
				"https://github.com/MaxMB15/MaxVideoPlayer/releases/latest/download/latest.json"
			]
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],

		"macOS": {
			"entitlements": "./Entitlements.plist",
			"frameworks": [],
			"files": {
				"Frameworks": "../../../libs/macos-bundle"
			},
			"infoPlist": "./Info.plist",
			"minimumSystemVersion": "10.15"
		},
		"linux": {
			"deb": {
				"depends": ["libmpv2 | libmpv1", "libegl1", "libgtk-3-0", "libwebkit2gtk-4.1-0"]
			},
			"rpm": {
				"depends": ["mpv-libs", "mesa-libEGL", "gtk3", "webkit2gtk4.1"]
			}
		}
	}
}
